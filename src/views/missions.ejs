<h1>Missioni</h1>
<p class="muted">Tocca una missione per inviare la tua prova. <span style="color:var(--green)"><%- icon('dot') %></span> = puoi farla ora.<br>
  <span class="small">Ogni missione si può fare <strong>una volta al giorno</strong> (il giorno va dalle 18:00 alle 17:59 del giorno dopo). Quelle <em>ripetibili</em> si possono rifare più volte.</span></p>

<%# ── Pronostico Palio dei Fuochi ─────────────────────────────────── %>
<% if (typeof pronostico !== 'undefined' && pronostico) { %>
  <section class="prono-card">
    <div class="prono-glow" aria-hidden="true"></div>
    <div class="prono-head">
      <span class="prono-ico"><%- icon('fireworks') %></span>
      <div>
        <p class="prono-kicker">Missione speciale · Pronostico</p>
        <h2 class="prono-title">Chi vince il Palio dei Fuochi?</h2>
      </div>
      <span class="prono-prize"><%= pronostico.points %> pt</span>
    </div>

    <% if (pronostico.resolved) { %>
      <%# Risultato dichiarato %>
      <% const won = pronostico.myChoice !== null && pronostico.myChoice === pronostico.winner; %>
      <div class="prono-result <%= won ? 'is-win' : (pronostico.myChoice !== null ? 'is-lose' : '') %>">
        <p class="prono-winner"><%- icon('trophy') %> Vincitore: <strong><%= pronostico.fuochisti[pronostico.winner] %></strong></p>
        <% if (won) { %>
          <p class="prono-outcome prono-outcome-win"><%- icon('sparkle') %> Hai indovinato! <strong>+<%= pronostico.points %> punti</strong> accreditati.</p>
        <% } else if (pronostico.myChoice !== null) { %>
          <p class="prono-outcome">Avevi scelto <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong>. Sarà per la prossima! 🎆</p>
        <% } else { %>
          <p class="prono-outcome">Non avevi fatto il tuo pronostico.</p>
        <% } %>
      </div>

    <% } else if (pronostico.open) { %>
      <%# Votazioni aperte %>
      <p class="prono-desc">Scegli <strong>un solo</strong> fuochista: se indovina il vincitore del Palio, ti porti a casa <strong><%= pronostico.points %> punti</strong>.
        <% if (pronostico.myChoice !== null) { %><br><span class="prono-current"><%- icon('check-circle') %> Il tuo pronostico: <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong> — puoi ancora cambiarlo.</span><% } %>
      </p>
      <form action="/missioni/pronostico" method="post" class="prono-form" data-saved="<%= pronostico.myChoice === null ? '' : pronostico.myChoice %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="prono-options">
          <% pronostico.fuochisti.forEach((name, i) => { %>
            <label class="prono-opt <%= pronostico.myChoice === i ? 'is-current' : '' %>">
              <input type="radio" name="choice" value="<%= i %>" <%= pronostico.myChoice === i ? 'checked' : '' %> required>
              <span class="prono-opt-num"><%= String(i + 1).padStart(2, '0') %></span>
              <span class="prono-opt-name"><%= name %></span>
              <span class="prono-opt-flag">in uscita</span>
              <span class="prono-opt-tick"><%- icon('check') %></span>
            </label>
          <% }) %>
        </div>
        <button class="btn prono-btn" type="submit"><%- icon('fireworks') %> <%= pronostico.myChoice !== null ? 'Aggiorna il pronostico' : 'Conferma il pronostico' %></button>
      </form>

    <% } else { %>
      <%# Chiuse, verdetto in attesa %>
      <p class="prono-desc"><%- icon('hourglass') %> Pronostici chiusi. In attesa del verdetto del Palio!
        <% if (pronostico.myChoice !== null) { %><br><span class="prono-current">Il tuo pronostico: <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong></span><% } %>
      </p>
    <% } %>
  </section>
<% } %>

<%# ── Pronostici generici (creati dall'admin) ─────────────────────── %>
<% if (typeof predictions !== 'undefined' && predictions && predictions.length) { %>
  <% predictions.forEach((pr) => { %>
    <section class="prono-card">
      <div class="prono-glow" aria-hidden="true"></div>
      <div class="prono-head">
        <span class="prono-ico"><%- icon('target') %></span>
        <div>
          <p class="prono-kicker">Pronostico</p>
          <h2 class="prono-title"><%= pr.title %></h2>
        </div>
        <span class="prono-prize"><%= pr.points %> pt</span>
      </div>

      <%
        const myNames = (pr.myChoices || []).map((i) => pr.options[i]).filter(Boolean);
        const hasVoted = myNames.length > 0;
      %>
      <% if (pr.resolved) { %>
        <% const won = (pr.myChoices || []).includes(pr.winner);
           const halved = won && pr.myChoices.length > 1; %>
        <div class="prono-result <%= won ? 'is-win' : (hasVoted ? 'is-lose' : '') %>">
          <p class="prono-winner"><%- icon('trophy') %> Esito: <strong><%= pr.options[pr.winner] %></strong></p>
          <% if (won) { %>
            <p class="prono-outcome prono-outcome-win"><%- icon('sparkle') %> Hai indovinato! <strong>+<%= halved ? Math.floor(pr.points / 2) : pr.points %> punti</strong> accreditati<% if (halved) { %> (metà, avevi scelto più risposte)<% } %>.</p>
          <% } else if (hasVoted) { %>
            <p class="prono-outcome">Avevi scelto <strong><%= myNames.join(', ') %></strong>. Sarà per la prossima!</p>
          <% } else { %>
            <p class="prono-outcome">Non avevi fatto il tuo pronostico.</p>
          <% } %>
        </div>
      <% } else if (pr.open) { %>
        <p class="prono-desc">
          <% if (pr.description) { %><%= pr.description %><br><% } else { %>Scegli <% if (pr.multi) { %>una o più opzioni<% } else { %><strong>una sola</strong> opzione<% } %>: se indovini, ti porti a casa <strong><%= pr.points %> punti</strong>.<br><% } %>
          <% if (pr.multi) { %><span class="prono-current"><%- icon('warning') %> Puoi scegliere più opzioni, ma se ne indichi più d'una i punti si <strong>dimezzano</strong>.</span><br><% } %>
          <% if (hasVoted) { %><span class="prono-current"><%- icon('check-circle') %> La tua scelta: <strong><%= myNames.join(', ') %></strong> — puoi ancora cambiarla.</span><% } %>
        </p>
        <form action="/pronostici/<%= pr.id %>/vota" method="post" class="prono-form" <% if (!pr.multi) { %>data-saved="<%= pr.myChoices.length ? pr.myChoices[0] : '' %>"<% } %>>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="prono-options">
            <% pr.options.forEach((name, i) => { const sel = (pr.myChoices || []).includes(i); %>
              <label class="prono-opt <%= sel ? 'is-current' : '' %>">
                <input type="<%= pr.multi ? 'checkbox' : 'radio' %>" name="choice" value="<%= i %>" <%= sel ? 'checked' : '' %> <%= pr.multi ? '' : 'required' %>>
                <span class="prono-opt-num"><%= String(i + 1).padStart(2, '0') %></span>
                <span class="prono-opt-name"><%= name %></span>
                <% if (!pr.multi) { %><span class="prono-opt-flag">in uscita</span><% } %>
                <span class="prono-opt-tick"><%- icon('check') %></span>
              </label>
            <% }) %>
          </div>
          <button class="btn prono-btn" type="submit"><%- icon('target') %> <%= hasVoted ? 'Aggiorna il pronostico' : 'Conferma il pronostico' %></button>
        </form>
      <% } else { %>
        <p class="prono-desc"><%- icon('hourglass') %> Pronostico chiuso. In attesa dell'esito!
          <% if (hasVoted) { %><br><span class="prono-current">La tua scelta: <strong><%= myNames.join(', ') %></strong></span><% } %>
        </p>
      <% } %>
    </section>
  <% }) %>
<% } %>

<%# ── Progresso sezioni (bonus al completamento) ──────────────────── %>
<% const secs = (typeof sections !== 'undefined' && sections) ? sections : []; %>
<% if (secs.length) { %>
  <section class="card ms-secpanel">
    <h2 class="staff-title"><%- icon('trophy') %> Sezioni · completa tutte le missioni di una sezione e prendi <strong>+<%= sectionBonus %> punti</strong></h2>
    <div class="ms-secgrid">
      <% secs.forEach((s) => { %>
        <div class="ms-secprog ms-sec-<%= s.color %> <%= s.completed ? 'is-done' : '' %>">
          <span class="ms-secprog-top">
            <span class="ms-secprog-name"><%= s.label %></span>
            <span class="ms-secprog-val"><%= s.done %>/<%= s.total %></span>
          </span>
          <span class="ms-secprog-bar"><span style="width:<%= Math.round(s.done / s.total * 100) %>%"></span></span>
          <span class="ms-secprog-foot">
            <% if (s.completed) { %><%- icon('check-circle') %> Completata · +<%= s.bonus %> pt<% } else { %>Mancano <%= s.total - s.done %> · +<%= s.bonus %> pt<% } %>
          </span>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>

<%
  // Raggruppa le missioni per sezione; quelle senza sezione (sfide giornaliere,
  // flash) finiscono in un gruppo a parte.
  const groups = [];
  secs.forEach((s) => {
    const ms = missions.filter((m) => m.section === s.key);
    if (ms.length) groups.push({ sec: s, list: ms });
  });
  const others = missions.filter((m) => !m.section);
  if (others.length) groups.push({ sec: null, list: others });
%>
<% groups.forEach((g) => { %>
  <% if (g.sec) { %>
    <div class="ms-sechead ms-sec-<%= g.sec.color %> <%= g.sec.completed ? 'is-done' : '' %>">
      <span><%= g.sec.label %> (<%= g.sec.total %>)</span>
      <span class="ms-sechead-badge"><%= g.sec.done %>/<%= g.sec.total %> · +<%= g.sec.bonus %> pt</span>
    </div>
  <% } else { %>
    <div class="ms-sechead ms-sec-other"><span>Sfide speciali</span></div>
  <% } %>

  <div class="mission-grid">
    <% g.list.forEach((m) => { %>
      <a class="mission-card <%= m.activeNow ? '' : 'inactive' %>" href="/missioni/<%= m.id %>">
        <div class="mission-head">
          <h3><%= m.title %></h3>
          <span class="points-badge"><%= m.points %> pt</span>
        </div>
        <p class="mission-desc"><%= m.description %></p>
        <div class="mission-meta">
          <% if (m.hasApproved && !m.repeatable) { %>
            <span class="tag tag-ok"><%- icon('check-circle') %> Fatta oggi</span>
          <% } else if (m.hasPending) { %>
            <span class="tag tag-pending"><%- icon('hourglass') %> In attesa</span>
          <% } %>
          <% if (m.repeatable) { %><span class="tag"><%- icon('repeat') %> Ripetibile</span><% } %>
          <% if (m.requires_photo) { %><span class="tag"><%- icon('camera') %> Foto</span><% } %>
          <% if (!m.activeNow) { %>
            <span class="tag tag-off"><%- icon('alarm') %> Non attiva ora</span>
          <% } else { %>
            <span class="tag tag-live"><%- icon('dot') %> Attiva</span>
          <% } %>
        </div>
        <div class="mission-counter">
          <span class="mc-icon"><%- icon('people') %></span>
          <span class="mc-val"><%= m.completedBy %></span>
          <span class="mc-label"><%= m.completedBy === 1 ? 'persona ha completato' : 'persone hanno completato' %></span>
        </div>
      </a>
    <% }) %>
  </div>
<% }) %>
<% if (missions.length === 0) { %>
  <p class="muted">Nessuna missione disponibile al momento. Torna più tardi!</p>
<% } %>
