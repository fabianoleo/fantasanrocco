<h1>Missioni</h1>
<p class="muted">Tocca una missione per inviare la tua prova. 🟢 = puoi farla ora.</p>

<div class="mission-grid">
  <% missions.forEach((m) => { %>
    <a class="mission-card <%= m.activeNow ? '' : 'inactive' %>" href="/missioni/<%= m.id %>">
      <div class="mission-head">
        <h3><%= m.title %></h3>
        <span class="points-badge"><%= m.points %> pt</span>
      </div>
      <p class="mission-desc"><%= m.description %></p>
      <div class="mission-meta">
        <% if (m.hasApproved && !m.repeatable) { %>
          <span class="tag tag-ok">✅ Completata</span>
        <% } else if (m.hasPending) { %>
          <span class="tag tag-pending">⏳ In attesa</span>
        <% } %>
        <% if (m.repeatable) { %><span class="tag">🔁 Ripetibile</span><% } %>
        <% if (m.requires_photo) { %><span class="tag">📷 Foto</span><% } %>
        <% if (!m.activeNow) { %><span class="tag tag-off">⏰ Non attiva ora</span>
        <% } else { %><span class="tag tag-live">🟢 Attiva</span><% } %>
      </div>
    </a>
  <% }) %>
</div>
<% if (missions.length === 0) { %>
  <p class="muted">Nessuna missione disponibile al momento. Torna più tardi!</p>
<% } %>
