<%# ── Hero ──────────────────────────────────────────────────────── %>
<div class="lb-hero">
  <p class="lp-kicker">Live</p>
  <h1 class="lb-hero-title">Classifica</h1>
  <p class="lb-hero-sub">La gara dei premi e i record del mini-gioco, in un colpo d'occhio.</p>
</div>

<%# ── Tab ───────────────────────────────────────────────────────── %>
<div class="lb-tabs" role="tablist">
  <button class="lb-tab active" type="button" role="tab" data-target="lbPanelGeneral"><%- icon('trophy') %> Generale</button>
  <button class="lb-tab" type="button" role="tab" data-target="lbPanelGame"><%- icon('bolt') %> Gioco</button>
</div>

<%# ════════════════════ PANNELLO GENERALE ════════════════════════ %>
<div class="lb-panel lb-panel-active" id="lbPanelGeneral">
<% if (rows.length === 0) { %>

  <div class="lb-empty">
    <span class="lb-empty-icon"><%- icon('trophy') %></span>
    <p>Ancora nessun punto assegnato.</p>
    <p class="muted small">Completa le prime missioni e sarai il primo in classifica.</p>
    <% if (currentUser) { %>
      <a href="/missioni" class="btn" style="margin-top:1.5rem">Vai alle missioni →</a>
    <% } %>
  </div>

<% } else { %>

  <%# ── Podio top 3 ─────────────────────────────────────────────── %>
  <% const top3 = rows.slice(0, 3); %>
  <% const rest = rows.slice(3); %>

  <div class="lb-podium-wrap">
    <% const podiumOrder = [top3[1], top3[0], top3[2]].filter(Boolean); %>
    <% podiumOrder.forEach((u, pi) => { %>
      <% const realIdx = top3.indexOf(u); %>
      <% const isMe    = currentUserId && u.id === currentUserId; %>
      <div class="lb-podium-card lb-podium-<%= ['gold','silver','bronze'][realIdx] %> <%= realIdx === 0 ? 'lb-podium-first' : '' %> <%= isMe ? 'lb-me' : '' %>">
        <span class="lb-podium-medal"><%- icon('medal') %></span>
        <span class="lb-podium-name"><%= u.nickname %><% if (isMe) { %> <span class="lb-you">tu</span><% } %></span>
        <span class="lb-podium-pts"><%= u.points %></span>
        <span class="lb-podium-pts-label">punti</span>
        <span class="lb-podium-done"><%= u.done %> missioni</span>
        <div class="lb-podium-bar lb-podium-bar-<%= ['gold','silver','bronze'][realIdx] %>"></div>
      </div>
    <% }) %>
  </div>

  <%# ── Lista dal 4° in poi ─────────────────────────────────────── %>
  <% if (rest.length > 0) { %>
  <div class="lb-list-wrap card">
    <h2 class="lb-list-title">Tutti i partecipanti</h2>
    <ol class="lb-list" start="4">
      <% rest.forEach((u, i) => { %>
        <% const isMe = currentUserId && u.id === currentUserId; %>
        <li class="lb-list-row <%= isMe ? 'lb-me' : '' %>">
          <span class="lb-list-rank"><%= i + 4 %></span>
          <span class="lb-list-name"><%= u.nickname %><% if (isMe) { %> <span class="lb-you">tu</span><% } %></span>
          <span class="lb-list-done"><%= u.done %> miss.</span>
          <span class="lb-list-pts"><%= u.points %><small>pt</small></span>
        </li>
      <% }) %>
    </ol>
  </div>
  <% } %>

<% } %>
</div>

<%# ════════════════════ PANNELLO GIOCO ═══════════════════════════ %>
<div class="lb-panel" id="lbPanelGame">
<% if (gameRows.length === 0) { %>

  <div class="lb-empty">
    <span class="lb-empty-icon"><%- icon('bolt') %></span>
    <p>Nessun punteggio registrato.</p>
    <p class="muted small">Sii il primo a correre con San Rocco e a entrare nella classifica del gioco.</p>
    <a href="/gioco" class="btn" style="margin-top:1.5rem"><%- icon('bolt') %> Vai al gioco</a>
  </div>

<% } else { %>

  <div class="lb-list-wrap card">
    <h2 class="lb-list-title">I migliori punteggi · «Corri San Rocco»</h2>
    <ol class="lb-list lb-list-game">
      <% gameRows.forEach((u, i) => { %>
        <% const isMe = currentUserId && u.id === currentUserId; %>
        <li class="lb-list-row <%= isMe ? 'lb-me' : '' %>">
          <span class="lb-list-rank">
            <% if (i < 3) { %><span class="lb-medal-inline <%= ['is-gold','is-silver','is-bronze'][i] %>"><%- icon('medal') %></span><% } else { %><%= i + 1 %><% } %>
          </span>
          <span class="lb-list-name"><%= u.nickname %><% if (isMe) { %> <span class="lb-you">tu</span><% } %></span>
          <span class="lb-list-pts"><%= u.best %><small>record</small></span>
        </li>
      <% }) %>
    </ol>
  </div>
  <p class="muted small" style="text-align:center;margin-top:1.2rem">
    Il punteggio record si aggiorna ad ogni partita su <a href="/gioco" style="color:var(--gold)">Corri San Rocco</a>.
  </p>

<% } %>
</div>
