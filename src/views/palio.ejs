<%# ── HERO ────────────────────────────────────────────────────── %>
<div class="palio-hero lp-full">
  <span class="palio-hero-glow" aria-hidden="true"></span>
  <div class="palio-hero-inner">
    <p class="palio-kicker"><%- icon('fireworks') %> 18 Agosto 2026 &nbsp;·&nbsp; Ore 22:30</p>
    <h1 class="palio-title">Palio dei Fuochi</h1>
    <p class="palio-sub">XXVI Edizione &mdash; Città di Siano (SA)</p>
    <p class="palio-memorial"><%- icon('candle') %> Memorial Don Franco Aliberti</p>
  </div>
</div>

<%# ── STRISCIA INFO ───────────────────────────────────────────── %>
<div class="palio-meta lp-full">
  <div class="palio-meta-grid">
    <div class="palio-meta-item">
      <span class="palio-meta-ico"><%- icon('moon') %></span>
      <span class="palio-meta-label">Data</span>
      <span class="palio-meta-val">18 Agosto</span>
    </div>
    <div class="palio-meta-item">
      <span class="palio-meta-ico"><%- icon('clock') %></span>
      <span class="palio-meta-label">Orario</span>
      <span class="palio-meta-val">Ore 22:30</span>
    </div>
    <div class="palio-meta-item">
      <span class="palio-meta-ico"><%- icon('flame') %></span>
      <span class="palio-meta-label">Edizione</span>
      <span class="palio-meta-val">XXVI</span>
    </div>
    <div class="palio-meta-item">
      <span class="palio-meta-ico"><%- icon('pin') %></span>
      <span class="palio-meta-label">Luogo</span>
      <span class="palio-meta-val">Siano (SA)</span>
    </div>
  </div>
</div>

<%# ── PRONOSTICO (spostato qui dalle Missioni) ────────────────── %>
<% if (typeof pronostico !== 'undefined' && pronostico) { %>
<section class="palio-section lp-full" id="pronostico">
  <div class="palio-section-inner">
  <section class="prono-card">
    <div class="prono-glow" aria-hidden="true"></div>
    <div class="prono-head">
      <span class="prono-ico"><%- icon('fireworks') %></span>
      <div>
        <p class="prono-kicker">Missione speciale · vale per "Paese &amp; Tradizione"</p>
        <h2 class="prono-title">Chi vince il Palio dei Fuochi?</h2>
      </div>
      <span class="prono-prize"><%= pronostico.points %> pt</span>
    </div>

    <% if (pronostico.resolved) { %>
      <%# Risultato dichiarato %>
      <% const won = pronostico.myChoice !== null && pronostico.myChoice === pronostico.winner; %>
      <div class="prono-result <%= won ? 'is-win' : (pronostico.myChoice !== null ? 'is-lose' : '') %>">
        <p class="prono-winner"><%- icon('trophy') %> Vincitore: <strong><%= pronostico.fuochisti[pronostico.winner] %></strong></p>
        <% if (won) { %>
          <p class="prono-outcome prono-outcome-win"><%- icon('sparkle') %> Hai indovinato! <strong>+<%= pronostico.points %> punti</strong> accreditati.</p>
        <% } else if (pronostico.myChoice !== null) { %>
          <p class="prono-outcome">Avevi scelto <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong>. Sarà per la prossima! 🎆</p>
        <% } else { %>
          <p class="prono-outcome">Non avevi fatto il tuo pronostico.</p>
        <% } %>
      </div>

    <% } else if (pronostico.open) { %>
      <%# Votazioni aperte %>
      <p class="prono-desc">Scegli <strong>un solo</strong> fuochista: se indovina il vincitore del Palio, ti porti a casa <strong><%= pronostico.points %> punti</strong>.
        <% if (pronostico.myChoice !== null) { %><br><span class="prono-current"><%- icon('check-circle') %> Il tuo pronostico: <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong> — puoi ancora cambiarlo.</span><% } %>
      </p>
      <% if (!currentUser) { %>
        <p class="prono-desc"><a class="btn prono-btn" href="/login"><%- icon('key') %> Accedi per fare il tuo pronostico</a></p>
      <% } else { %>
      <form action="/missioni/pronostico" method="post" class="prono-form" data-saved="<%= pronostico.myChoice === null ? '' : pronostico.myChoice %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="prono-options">
          <% pronostico.fuochisti.forEach((name, i) => { %>
            <label class="prono-opt <%= pronostico.myChoice === i ? 'is-current' : '' %>">
              <input type="radio" name="choice" value="<%= i %>" <%= pronostico.myChoice === i ? 'checked' : '' %> required>
              <span class="prono-opt-num"><%= String(i + 1).padStart(2, '0') %></span>
              <span class="prono-opt-name"><%= name %></span>
              <span class="prono-opt-flag">in uscita</span>
              <span class="prono-opt-tick"><%- icon('check') %></span>
            </label>
          <% }) %>
        </div>
        <button class="btn prono-btn" type="submit"><%- icon('fireworks') %> <%= pronostico.myChoice !== null ? 'Aggiorna il pronostico' : 'Conferma il pronostico' %></button>
      </form>
      <% } %>

    <% } else { %>
      <%# Chiuse, verdetto in attesa %>
      <p class="prono-desc"><%- icon('hourglass') %> Pronostici chiusi. In attesa del verdetto del Palio!
        <% if (pronostico.myChoice !== null) { %><br><span class="prono-current">Il tuo pronostico: <strong><%= pronostico.fuochisti[pronostico.myChoice] %></strong></span><% } %>
      </p>
    <% } %>
    </section>
  </div>
</section>
<% } %>

<%# ── I SEI FUOCHISTI ─────────────────────────────────────────── %>
<section class="palio-section lp-full">
  <div class="palio-section-inner">
    <header class="palio-section-head">
      <p class="palio-section-kicker">La sfida nel cielo di Siano</p>
      <h2 class="palio-section-title">I sei fuochisti e i rioni</h2>
      <p class="palio-section-sub">Ogni squadra pirotecnica gareggia per i propri rioni: sei spettacoli, un solo cielo.</p>
    </header>

    <div class="palio-grid">
      <% fuochisti.forEach((f, i) => { %>
        <article class="palio-card">
          <div class="palio-card-top">
            <span class="palio-num"><%= String(i + 1).padStart(2, '0') %></span>
            <div class="palio-card-titles">
              <h3 class="palio-name"><%= f.name %></h3>
              <% if (f.place) { %><p class="palio-place"><%- icon('pin') %><%= f.place %></p><% } %>
            </div>
          </div>
          <p class="palio-rioni-label"><%= f.rioni.length > 1 ? 'Rioni' : 'Rione' %></p>
          <ul class="palio-rioni">
            <% f.rioni.forEach((r) => { %>
              <li class="palio-rione"><%= r %></li>
            <% }) %>
          </ul>
          <% if (f.note) { %>
            <p class="palio-note"><%- icon('sparkle') %> <%= f.note %></p>
          <% } %>
        </article>
      <% }) %>
    </div>

    <div class="palio-back">
      <a href="/programmazione" class="palio-back-link"><%- icon('repeat') %> Torna alla programmazione</a>
    </div>
  </div>
</section>
