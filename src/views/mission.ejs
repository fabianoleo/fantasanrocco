<a href="/missioni" class="back">← Tutte le missioni</a>

<section class="card">
  <% const r = missionParts(m.title); %>
  <div class="mission-head">
    <h1><span class="m-bonus big">BONUS</span> <span class="m-name"><%= r.name %></span></h1>
    <span class="points-badge big"><%= m.points %> pt</span>
  </div>
  <p><%= m.description %></p>

  <div class="mission-meta">
    <% if (r.label) { %><span class="rar-chip rar-<%= r.key %>"><span class="rar-dot" aria-hidden="true"><%= r.emoji %></span> <%= r.label %></span><% } %>
    <% if (m.repeatable) { %><span class="tag"><%- icon('repeat') %> Ripetibile (più volte)</span><% } else { %><span class="tag">1 volta al giorno</span><% } %>
    <% if (m.requires_photo) { %><span class="tag"><%- icon('camera') %> Foto obbligatoria</span><% } else { %><span class="tag">Senza foto</span><% } %>
    <% if (activeNow) { %><span class="tag tag-live"><%- icon('dot') %> Attiva ora</span><% } else { %><span class="tag tag-off"><%- icon('alarm') %> Non attiva ora</span><% } %>
  </div>

  <% if (m.active_from || m.active_to) { %>
    <p class="muted small">Finestra valida:
      <%= m.active_from || 'sempre' %> → <%= m.active_to || 'sempre' %></p>
  <% } %>
</section>

<% if (statuses.includes('approved') && !m.repeatable) { %>
  <div class="card"><p class="tag-ok"><%- icon('check-circle') %> Fatta oggi! Potrai rifarla dal prossimo giorno-festa (dalle 18:00).</p></div>
<% } else if (statuses.includes('pending')) { %>
  <div class="card"><p class="tag-pending"><%- icon('hourglass') %> Hai una prova in attesa di validazione per questa missione.</p></div>
<% } %>

<% if (canSubmit && activeNow) { %>
  <section class="card">
    <h2>Invia la tua prova</h2>
    <form action="/missioni/<%= m.id %>/invia" method="post" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% if (m.requires_photo) { %>
        <label>Foto (obbligatoria)
          <input type="file" name="foto" accept="image/*" required>
        </label>
      <% } else { %>
        <label>Foto (facoltativa)
          <input type="file" name="foto" accept="image/*">
        </label>
      <% } %>
      <p class="muted small" style="margin-top:.4rem">Puoi scattare al momento o scegliere una foto dalla galleria.</p>
      <label>Nota per lo staff (facoltativa)
        <input type="text" name="note" maxlength="200" placeholder="es. erano le 23, vicino alla cassa">
      </label>
      <button class="btn" type="submit" data-haptic>Invia prova</button>
    </form>
  </section>
<% } else if (!activeNow) { %>
  <div class="card"><p class="muted">Questa missione non è attiva in questo momento: torna nella finestra giusta.</p></div>
<% } %>
