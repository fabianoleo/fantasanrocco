<section class="card center" style="max-width:420px;margin:2.5rem auto">
  <h1>Verifica in due passaggi</h1>
  <p class="muted">Inserisci il codice a 6 cifre della tua app di autenticazione (o un codice di recupero).</p>
  <form action="/login/2fa" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Codice
      <input type="text" name="code" inputmode="numeric" autocomplete="one-time-code" autofocus required placeholder="123456" style="text-align:center;letter-spacing:.3em;font-size:1.2rem">
    </label>
    <button class="btn" type="submit">Verifica</button>
  </form>
  <p class="muted small" style="margin-top:1rem"><a href="/login">← Torna al login</a></p>
</section>
