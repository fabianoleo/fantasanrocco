<%# ── HERO ─────────────────────────────────────────────────────── %>
<div class="pz-hero lp-full">
  <div class="pz-hero-inner">
    <p class="pz-hero-kicker">Festa di San Rocco 2026 &nbsp;·&nbsp; Siano</p>
    <h1 class="pz-title">I Premi<br>in Palio</h1>
    <p class="pz-subtitle">Chi sale in cima alla classifica porta a casa un premio.<br>Quest'anno però i premi sono <strong>ancora un mistero</strong>: verranno svelati presto.</p>
    <div class="pz-hero-pill">
      <span>3</span> premi &nbsp;&middot;&nbsp; <span>?</span> ancora segreti &nbsp;&middot;&nbsp; <span>agosto&nbsp;2026</span>
    </div>
  </div>
</div>

<% /* ═══════════════════════════════════════════════════════════════════
   PREMI UFFICIALI — NASCOSTI PER ORA (restano segreti fino allo svelamento).
   Il blocco qui sotto è disattivato con `if (false)`: NON viene mostrato,
   ma è conservato integralmente. Per rivelare di nuovo i premi basta
   cambiare `if (false)` in `if (true)` (e rimuovere le sezioni "mistero").
   ═══════════════════════════════════════════════════════════════════ */ %>
<% if (false) { %>
<%# ── PRIMO POSTO ─────────────────────────────────────────────── %>
<div class="pz-section pz-gold lp-full">
  <div class="pz-rank-ghost">I</div>
  <div class="pz-section-inner">
    <div class="pz-section-info">
      <div class="pz-rank-label">
        <span class="pz-medal"><%- icon('medal') %></span>
        <span>Primo Posto</span>
      </div>
      <div class="pz-divider"></div>
      <h2 class="pz-prize-name">Smartbox<br>3 giorni da sogno</h2>
      <p class="pz-prize-tagline">In Europa, per 2 persone, quando vuoi tu</p>
      <p class="pz-prize-desc">Un cofanetto regalo con centinaia di strutture in tutta Europa. Scegli la destinazione, scegli il momento. Tre giorni indimenticabili per due persone.</p>
      <ul class="pz-details">
        <li><%- icon('gift') %> Cofanetto Smartbox originale</li>
        <li><%- icon('globe') %> Valido in tutta Europa</li>
        <li><%- icon('people') %> Per 2 persone</li>
        <li><%- icon('hotel') %> 3 giorni / 2 notti</li>
      </ul>
    </div>
    <div class="pz-photos-area">
      <% if (smartboxCover && smartboxDest) { %>
        <div class="pz-photos-duo">
          <div class="pz-photo pz-photo-border-gold">
            <img src="/images/premi/<%= smartboxCover %>" alt="Smartbox copertina">
          </div>
          <div class="pz-photo pz-photo-border-gold">
            <img src="/images/premi/<%= smartboxDest %>" alt="Destinazioni Europa">
          </div>
        </div>
      <% } else if (smartboxCover) { %>
        <div class="pz-photo pz-photo-single pz-photo-border-gold">
          <img src="/images/premi/<%= smartboxCover %>" alt="Smartbox">
        </div>
      <% } else { %>
        <div class="pz-photo-placeholder">
          <span class="pz-ph-icon"><%- icon('gift') %></span>
          <span>Foto in arrivo</span>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%# ── SECONDO POSTO ───────────────────────────────────────────── %>
<div class="pz-section pz-silver lp-full">
  <div class="pz-rank-ghost">II</div>
  <div class="pz-section-inner">
    <div class="pz-section-info">
      <div class="pz-rank-label">
        <span class="pz-medal"><%- icon('medal') %></span>
        <span>Secondo Posto</span>
      </div>
      <div class="pz-divider"></div>
      <h2 class="pz-prize-name">Nintendo<br>Switch Lite</h2>
      <p class="pz-prize-tagline">La console portatile, ovunque tu voglia</p>
      <p class="pz-prize-desc">Leggera, compatta, perfetta per giocare dovunque. Centinaia di titoli disponibili: dal party game all'avventura, la Switch Lite è gaming puro.</p>
      <ul class="pz-details">
        <li><%- icon('gamepad') %> Nintendo Switch Lite</li>
        <li><%- icon('box') %> Versione portatile e leggera</li>
        <li><%- icon('target') %> Centinaia di giochi disponibili</li>
      </ul>
    </div>
    <div class="pz-photos-area">
      <% if (photoPs5) { %>
        <div class="pz-photo pz-photo-single pz-photo-border-silver">
          <img src="/images/premi/<%= photoPs5 %>" alt="Nintendo Switch Lite">
        </div>
      <% } else { %>
        <div class="pz-photo-placeholder">
          <span class="pz-ph-icon"><%- icon('gamepad') %></span>
          <span>Foto in arrivo</span>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%# ── TERZO POSTO ─────────────────────────────────────────────── %>
<div class="pz-section pz-bronze lp-full">
  <div class="pz-rank-ghost">III</div>
  <div class="pz-section-inner">
    <div class="pz-section-info">
      <div class="pz-rank-label">
        <span class="pz-medal"><%- icon('medal') %></span>
        <span>Terzo Posto</span>
      </div>
      <div class="pz-divider"></div>
      <h2 class="pz-prize-name">Macchina<br>del Caffè</h2>
      <p class="pz-prize-tagline">Perché le grandi imprese meritano un gran caffè</p>
      <p class="pz-prize-desc">Dopo tante missioni completate, il caffè perfetto è il tuo premio. Una macchina di qualità per iniziare ogni mattina alla grande.</p>
      <ul class="pz-details">
        <li><%- icon('coffee') %> Macchina espresso automatica</li>
        <li><%- icon('bean') %> Cialde omaggio incluse</li>
        <li><%- icon('sparkle') %> Design da cucina di qualità</li>
      </ul>
    </div>
    <div class="pz-photos-area">
      <% if (photoCaffe) { %>
        <div class="pz-photo pz-photo-single pz-photo-border-bronze">
          <img src="/images/premi/<%= photoCaffe %>" alt="Macchinetta del caffè">
        </div>
      <% } else { %>
        <div class="pz-photo-placeholder">
          <span class="pz-ph-icon"><%- icon('coffee') %></span>
          <span>Foto in arrivo</span>
        </div>
      <% } %>
    </div>
  </div>
</div>

<% } /* fine premi ufficiali nascosti */ %>

<%# ══ PREMI MISTERIOSI (mostrati al posto di quelli ufficiali) ══════════ %>
<%
  const mysteryRanks = [
    { cls: 'pz-gold',   ghost: 'I',   label: 'Primo Posto' },
    { cls: 'pz-silver', ghost: 'II',  label: 'Secondo Posto' },
    { cls: 'pz-bronze', ghost: 'III', label: 'Terzo Posto' },
  ];
  mysteryRanks.forEach((rk) => { %>
  <div class="pz-section <%= rk.cls %> lp-full">
    <div class="pz-rank-ghost">?</div>
    <div class="pz-section-inner">
      <div class="pz-section-info">
        <div class="pz-rank-label">
          <span class="pz-medal"><%- icon('medal') %></span>
          <span><%= rk.label %></span>
        </div>
        <div class="pz-divider"></div>
        <h2 class="pz-prize-name">Premio<br>Misterioso</h2>
        <p class="pz-prize-tagline">Ancora top secret &nbsp;·&nbsp; svelato presto</p>
        <p class="pz-prize-desc">Il premio per il <%= rk.label.toLowerCase() %> è ancora un segreto. Sarà rivelato prima della festa: continua a giocare e scala la classifica, chi arriva in cima non resterà deluso.</p>
        <ul class="pz-details">
          <li><%- icon('lock') %> Premio ancora segreto</li>
          <li><%- icon('sparkle') %> Verrà svelato a breve</li>
          <li><%- icon('trophy') %> Riservato ai primi in classifica</li>
        </ul>
      </div>
      <div class="pz-photos-area">
        <div class="pz-photo-placeholder pz-photo-mystery">
          <span class="pz-ph-icon"><%- icon('gift') %></span>
          <span>?</span>
          <span class="pz-ph-note">Sarà svelato presto</span>
        </div>
      </div>
    </div>
  </div>
<% }) %>

<%# ── COME SI VINCE ────────────────────────────────────────────── %>
<div class="pz-how lp-full">
  <div class="pz-how-inner">
    <p class="pz-how-kicker">Regolamento</p>
    <h2 class="pz-how-title">Come si vince</h2>
    <div class="pz-steps">
      <div class="pz-step">
        <span class="pz-step-num">01</span>
        <div>
          <p class="pz-step-title">Completa le missioni</p>
          <p class="pz-step-desc">Ogni missione vale un numero di punti. Più missioni completi, più punti accumuli nella settimana della festa.</p>
        </div>
      </div>
      <div class="pz-step">
        <span class="pz-step-num">02</span>
        <div>
          <p class="pz-step-title">Invia la prova</p>
          <p class="pz-step-desc">Fotografia, video o descrizione: carica la tua prova per ogni missione completata. Lo staff la verificherà e ti assegnerà i punti.</p>
        </div>
      </div>
      <div class="pz-step">
        <span class="pz-step-num">03</span>
        <div>
          <p class="pz-step-title">Sali in classifica</p>
          <p class="pz-step-desc">I punti approvati entrano subito in classifica. Tieni d'occhio il tabellone: la gara è aperta fino alla fine della festa.</p>
        </div>
      </div>
      <div class="pz-step">
        <span class="pz-step-num">04</span>
        <div>
          <p class="pz-step-title">Vinci il premio</p>
          <p class="pz-step-desc">I primi tre in classifica a fine festa si aggiudicano i premi. Chi ne ha di più, vince.</p>
        </div>
      </div>
    </div>
    <div class="pz-how-cta">
      <% if (!currentUser) { %>
        <a class="btn" href="/login">Accedi e gioca &rarr;</a>
      <% } else { %>
        <a class="btn" href="/missioni">Vai alle missioni &rarr;</a>
      <% } %>
    </div>
  </div>
</div>
