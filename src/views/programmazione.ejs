      <div class="pg-grande-glow" style="background: radial-gradient(ellipse at 50% 0%, rgba(232,78,27,.25) 0%, transparent 70%);"></div>
      <div class="pg-card-time">
        <span class="pg-time-icon"><%- icon('fireworks') %></span>
        <span class="pg-time-val">22:30</span>
        <span class="pg-time-label">Notte</span>
      </div>
      <div class="pg-card-body">
        <div class="pg-card-meta">
          <span class="pg-location"><%- icon('pin') %>Siano</span>
        </div>
        <h2 data-map-place="siano-centro" class="pg-card-title pg-title-grande" style="-webkit-text-fill-color: var(--fire) !important; color: var(--fire) !important; text-shadow: 0 0 28px rgba(232,78,27,.5);">Palio dei Fuochi</h2>
        <p class="pg-card-subtitle-tour">XXVI Edizione &middot; Memorial Don Franco Aliberti</p>
        <p class="pg-card-desc">Lo spettacolo pirotecnico più atteso dell'anno: sei squadre di artificieri, ognuna legata ai propri rioni, si sfidano nel cielo di Siano in una gara di luci, colori e botti che ha reso la festa famosa in tutta Italia.</p>
        <div class="pg-badges">
          <span class="pg-badge pg-badge-big"><%- icon('flame') %> Grande Evento</span>
          <span class="pg-badge" style="background:rgba(232,78,27,.15);color:#e84e1b;border-color:rgba(232,78,27,.3)"><%- icon('fireworks') %> Fuochi d'Artificio</span>
        </div>
        <div class="pg-ig-row">
          <a class="pg-ig" href="/palio" aria-label="Scopri i sei fuochisti e i rioni del Palio dei Fuochi"><%- icon('fireworks') %><span>Scopri i 6 fuochisti e i rioni &rarr;</span></a>
        </div>
      </div>
    </article>
  </div>
</div>

<%# ── MAPPA DEI LUOGHI (Leaflet + OpenStreetMap) ──────────────────── %>
<% if (typeof places !== 'undefined' && places && places.length) { %>
<section class="sia-wrap lp-full" id="mappa">
  <div class="sia-hero-inner" style="text-align:center;margin-bottom:1.2rem">
    <p class="lp-kicker">Siano (SA)</p>
    <h2 class="sia-title" style="font-size:clamp(1.6rem,5vw,2.4rem)">I luoghi della festa</h2>
    <p class="sia-sub">Tocca un punto sulla mappa o nella lista per vedere gli eventi collegati.</p>
  </div>
  <div class="sia-grid">
    <div class="sia-map-col">
      <div id="siaMap" class="sia-map" aria-label="Mappa di Siano"></div>
      <button class="sia-reset" id="siaReset" type="button" hidden>
        <%- icon('repeat') %> Torna alla vista generale
      </button>
    </div>
    <aside class="sia-side">
      <div class="sia-card" id="siaCard" hidden>
        <span class="sia-card-handle" aria-hidden="true"></span>
        <button class="sia-card-close" id="siaCardClose" type="button" aria-label="Chiudi">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="sia-card-media" id="siaCardMedia" hidden><span class="sia-card-media-grad"></span></div>
        <div class="sia-card-content">
          <div class="sia-card-head">
            <span class="sia-card-num" id="siaCardNum"></span>
            <div>
              <span class="sia-card-kicker"><%- icon('pin') %><span id="siaCardAddr"></span></span>
              <h3 class="sia-card-name" id="siaCardName"></h3>
            </div>
          </div>
          <p class="sia-card-desc" id="siaCardDesc" hidden></p>
          <div class="sia-card-events" id="siaCardEvents"></div>
        </div>
      </div>
      <div class="sia-list" id="siaList">
        <h2 class="sia-list-title">Esplora i luoghi</h2>
        <ul class="sia-list-items">
          <% places.forEach((p, i) => { %>
            <li>
              <button class="sia-li" data-place="<%= p.id %>" data-num="<%= i + 1 %>" <%= p.coordinates ? '' : 'data-nocoord="1"' %>>
                <span class="sia-li-num"><%= i + 1 %></span>
                <span class="sia-li-body">
                  <span class="sia-li-name"><%= p.name %></span>
                  <span class="sia-li-meta">
                    <%= p.events.length %> <%= p.events.length === 1 ? 'evento' : 'eventi' %><% if (!p.coordinates) { %> · <em>da posizionare</em><% } %>
                  </span>
                </span>
                <span class="sia-li-arrow"><%- icon('chevron-right') %></span>
              </button>
            </li>
          <% }) %>
        </ul>
        <p class="sia-list-note">Mappa © OpenStreetMap contributors · © CARTO</p>
      </div>
    </aside>
  </div>
</section>

<script type="application/json" id="siaPlaces"><%- JSON.stringify(places).replace(/</g, '\\u003c') %></script>
<script src="/vendor/leaflet.js" defer></script>
<script src="/map.js?v=6" defer></script>
<% } %>
