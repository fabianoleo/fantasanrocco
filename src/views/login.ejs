<section class="card form-card">
  <h1>Accedi</h1>
  <form action="/login" method="post" autocomplete="off">
    <label>Nickname
      <input type="text" name="nickname" required placeholder="il tuo nickname">
    </label>
    <label>Password
      <input type="password" name="password" required placeholder="la tua password">
    </label>
    <button class="btn" type="submit">Entra</button>
  </form>
  <p class="muted" style="margin-top:.6rem">
    <a href="/password-dimenticata">Password dimenticata?</a>
  </p>
  <p class="muted">Non hai un account? <a href="/registrati">Registrati</a>.</p>
</section>
