<link rel="stylesheet" href="/gallery.css?v=1">

<%# ── HERO ────────────────────────────────────────────────────────── %>
<div class="gl-hero lp-full">
  <div class="gl-hero-inner">
    <p class="lp-kicker" style="margin-bottom:.9rem;letter-spacing:.22em">Siano &nbsp;·&nbsp; Festa di San Rocco</p>
    <h1 class="gl-title">Galleria</h1>
    <p class="gl-sub">Le immagini della festa. Tocca una foto per aprirla, poi scorri tra le altre dal dock.</p>
    <div class="gl-hero-count">
      <span><%= processione.length + devozione.length + luoghi.length + palio.length %></span> fotografie
    </div>
  </div>
</div>

<%# ── 01 LA PROCESSIONE ──────────────────────────────────────────── %>
<div class="gl-section lp-full">
  <div class="gl-section-inner">
    <div class="gl-section-head">
      <span class="gl-section-num">01</span>
      <div>
        <h2 class="gl-section-title">La Processione</h2>
        <p class="gl-section-desc">Il Santo portato a spalla tra le vie di Siano, tra applausi, preghiere e fuochi d'artificio.</p>
      </div>
    </div>
    <%- include('partials/bento-grid', { items: processione, sec: 'processione', label: 'La Processione' }) %>
  </div>
</div>

<%# ── 02 LA DEVOZIONE ────────────────────────────────────────────── %>
<div class="gl-section gl-section-alt lp-full">
  <div class="gl-section-inner">
    <div class="gl-section-head">
      <span class="gl-section-num">02</span>
      <div>
        <h2 class="gl-section-title">Il Popolo e la Devozione</h2>
        <p class="gl-section-desc">La fede che si tocca con mano: i volti, i gesti, l'oro donato al Santo per generazioni.</p>
      </div>
    </div>
    <%- include('partials/bento-grid', { items: devozione, sec: 'devozione', label: 'Il Popolo e la Devozione' }) %>
  </div>
</div>

<%# ── 03 IL PALIO DEI FUOCHI ─────────────────────────────────────── %>
<div class="gl-section gl-section-palio lp-full">
  <div class="gl-section-inner">
    <div class="gl-section-head">
      <span class="gl-section-num" style="color:var(--fire);text-shadow:0 0 30px rgba(232,78,27,.4)">03</span>
      <div>
        <h2 class="gl-section-title">Il Palio dei Fuochi</h2>
        <p class="gl-section-desc">I maestri fuochisti, le bombe da tiro, il cielo di Siano illuminato a festa — rinomato in tutta Italia.</p>
      </div>
    </div>
    <%- include('partials/bento-grid', { items: palio, sec: 'palio', label: 'Il Palio dei Fuochi' }) %>
  </div>
</div>

<%# ── 04 LA PIAZZA E IL CAMPANILE ────────────────────────────────── %>
<div class="gl-section lp-full">
  <div class="gl-section-inner">
    <div class="gl-section-head">
      <span class="gl-section-num">04</span>
      <div>
        <h2 class="gl-section-title">La Piazza e il Campanile</h2>
        <p class="gl-section-desc">I simboli del cuore di Siano: la piazza, il campanile e i fuochi che illuminano la notte.</p>
      </div>
    </div>
    <%- include('partials/bento-grid', { items: luoghi, sec: 'luoghi', label: 'La Piazza e il Campanile' }) %>
  </div>
</div>

<%# ── CREDITI FOTOGRAFICI ───────────────────────────────────────────── %>
<div class="gl-credits lp-full">
  <div class="gl-credits-inner">
    <h2 class="gl-credits-title">Crediti fotografici</h2>
    <p class="gl-credits-text">
      Alcune fotografie presenti in questa galleria sono di proprietà dei rispettivi
      fotografi e vengono pubblicate con la loro autorizzazione.
    </p>
    <p class="gl-credits-thanks">Ringraziamo:</p>
    <ul class="gl-credits-list">
      <li>Di Filippo Fotografi</li>
      <li>Luigi Bianchi</li>
      <li>Fotografia XYZ</li>
    </ul>
  </div>
</div>

<%# ── MODALE LIGHTBOX + DOCK (condiviso da tutte le sottosezioni) ─── %>
<div class="bento-modal" id="bentoModal" role="dialog" aria-modal="true" aria-label="Foto a schermo intero">
  <div class="bm-backdrop"></div>
  <div class="bm-stage">
    <div class="bm-figure">
      <img class="bm-img" src="" alt="">
      <div class="bm-caption">
        <p class="bm-kicker"></p>
        <p class="bm-title"></p>
      </div>
    </div>
    <button class="bm-nav bm-prev" type="button" aria-label="Foto precedente"><%- icon('chevron-left') %></button>
    <button class="bm-nav bm-next" type="button" aria-label="Foto successiva"><%- icon('chevron-right') %></button>
    <button class="bm-close" type="button" aria-label="Chiudi"><%- icon('x') %></button>
  </div>
</div>
<div class="bm-dock" id="bmDock" aria-label="Naviga tra le foto">
  <div class="bm-dock-inner">
    <span class="bm-dock-handle" aria-hidden="true"></span>
  </div>
</div>

<script src="/gallery.js?v=1" defer></script>
