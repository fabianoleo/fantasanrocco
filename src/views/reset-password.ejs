<section class="card form-card">
  <h1>🔒 Nuova password</h1>
  <p class="muted">Scegli una nuova password sicura (minimo 8 caratteri).</p>
  <form action="/reset-password/<%= token %>" method="post" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Nuova password
      <input type="password" name="password" required minlength="8" placeholder="almeno 8 caratteri">
    </label>
    <label>Conferma password
      <input type="password" name="confirm" required minlength="8" placeholder="ripeti la password">
    </label>
    <button class="btn" type="submit">Salva nuova password</button>
  </form>
</section>
