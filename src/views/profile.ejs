<%
  const approvedCount = subs.filter(s => s.status === 'approved').length;
  const pendingCount  = subs.filter(s => s.status === 'pending').length;
%>

<%# ── HERO ────────────────────────────────────────────────────────── %>
<div class="pf-hero lp-full">
  <div class="pf-hero-inner">
    <%- include('partials/avatar', { user: currentUser, cls: 'avatar-xl pf-avatar', online: true }) %>
    <p class="lp-kicker" style="margin-bottom:.4rem">Il tuo profilo</p>
    <h1 class="pf-name"><%= currentUser.nickname %></h1>
    <div class="pf-score-wrap">
      <span class="pf-pts"><%= total %></span>
      <span class="pf-pts-label">punti</span>
    </div>
  </div>
</div>

<%# ── STATS ──────────────────────────────────────────────────────── %>
<div class="pf-stats-strip lp-full">
  <div class="pf-stat">
    <span class="pf-stat-val"><%= approvedCount %></span>
    <span class="pf-stat-label">completate</span>
  </div>
  <div class="pf-stat">
    <span class="pf-stat-val"><%= pendingCount %></span>
    <span class="pf-stat-label">in attesa</span>
  </div>
  <div class="pf-stat">
    <span class="pf-stat-val">105</span>
    <span class="pf-stat-label">missioni totali</span>
  </div>
</div>

<%# ── LIVELLO ─────────────────────────────────────────────────────── %>
<div class="pf-level">
  <span class="pf-level-badge">Lv <b><%= level.level %></b></span>
  <div class="pf-level-info">
    <div class="pf-level-row">
      <span class="pf-level-title"><%= level.title %></span>
      <span class="pf-level-next"><%= level.max ? 'Livello massimo' : (level.toNext + ' pt al Lv ' + (level.level + 1)) %></span>
    </div>
    <div class="pf-level-bar"><span style="width:<%= level.progress %>%"></span></div>
    <% if (!level.max) { %><span class="pf-level-nexttitle">Prossimo: <%= level.nextTitle %></span><% } %>
  </div>
</div>

<%# ── STREAK GIORNALIERA ──────────────────────────────────────────── %>
<div class="pf-streak">
  <div class="pf-streak-head">
    <span class="pf-streak-title"><%- icon('flame') %> Striscia giornaliera</span>
    <span class="pf-streak-sub"><%= streak.currentDay > 0 ? ('Giorno ' + streak.currentDay + ' / 7') : 'Non ancora iniziata' %></span>
  </div>
  <div class="pf-streak-days">
    <% streak.bonuses.forEach((b, i) => { const d = i + 1; %>
      <div class="pf-streak-day <%= d <= streak.currentDay ? 'is-on' : '' %> <%= d === streak.currentDay ? 'is-current' : '' %>">
        <span class="pf-streak-d">G<%= d %></span>
        <span class="pf-streak-b">+<%= b %></span>
      </div>
    <% }) %>
  </div>
  <% if (streak.claimable) { %>
    <p class="pf-streak-cta">Premio di oggi pronto: <b>Giorno <%= streak.day %> · +<%= streak.bonus %> punti</b></p>
  <% } %>
</div>

<%# ── VETRINA TRAGUARDI / BADGE ───────────────────────────────────── %>
<h2 class="pf-section-title">Traguardi <span class="pf-badge-count"><%= badges.filter((b) => b.done).length %>/<%= badges.length %></span></h2>
<div class="pf-badges">
  <% badges.forEach((b) => { %>
    <div class="pf-badge <%= b.done ? 'is-done' : 'is-locked' %>" title="<%= b.desc %>">
      <span class="pf-badge-ic"><%- b.done ? icon('medal') : icon('lock') %></span>
      <span class="pf-badge-name"><%= b.title %></span>
      <span class="pf-badge-pts">+<%= b.points %></span>
    </div>
  <% }) %>
</div>

<%# ── NOTIFICHE PUSH ──────────────────────────────────────────────── %>
<section class="push-box">
  <h2 class="pf-section-title">Avvisi della festa <span class="pf-badge-pts">+100</span></h2>
  <p class="muted small">Ricevi una notifica per gli eventi importanti — Palio dei Fuochi, nuove missioni, sorpassi in classifica — e prendi subito <strong>+100 punti bonus</strong>.<br>
  I 100 punti valgono <strong>finché tieni gli avvisi attivi</strong>: se li disattivi ti vengono tolti (anche in negativo).</p>
  <button id="pushBtn" type="button" class="btn">🔔 Attiva avvisi (+100 punti)</button>
</section>

<%# ── STORICO PUNTI ─────────────────────────────────────────────────── %>
<h2 class="pf-section-title">Storico punti</h2>
<%
  const approvedSubs = subs.filter((s) => s.status === 'approved');
  const missionPts = approvedSubs.reduce((a, s) => a + (s.points || 0), 0);
  const otherPts = total - missionPts;   // ruota, slot, premi, bonus avvisi… (points_adjust)
%>
<div class="pf-points-card">
  <ul class="pf-history">
    <% approvedSubs.forEach((s) => { %>
      <li class="pf-hist-row">
        <span class="pf-hist-pts pos">+<%= s.points %></span>
        <span class="pf-hist-label"><%= s.title %></span>
        <span class="pf-hist-date"><%= (s.reviewed_at || s.created_at || '').slice(0, 10) %></span>
      </li>
    <% }) %>
    <% if (otherPts !== 0) { %>
      <li class="pf-hist-row">
        <span class="pf-hist-pts <%= otherPts > 0 ? 'pos' : 'neg' %>"><%= otherPts > 0 ? '+' : '' %><%= otherPts %></span>
        <span class="pf-hist-label">Giochi e bonus <span class="muted small">· ruota, slot, premi, avvisi</span></span>
        <span class="pf-hist-date">—</span>
      </li>
    <% } %>
    <% if (!approvedSubs.length && otherPts === 0) { %>
      <li class="pf-hist-empty">Ancora nessun punto: completa una missione o attiva gli avvisi!</li>
    <% } %>
  </ul>
  <div class="pf-hist-total"><span>Totale</span><strong><%= total %> punti</strong></div>
</div>

<%# ── PROVE ──────────────────────────────────────────────────────── %>
<h2 class="pf-section-title">Le mie prove</h2>

<% if (subs.length === 0) { %>
  <div class="pf-empty">
    Non hai ancora inviato nessuna prova.<br>
    <a href="/missioni" style="color:var(--gold);text-decoration:none;font-style:normal">Inizia ora →</a>
  </div>
<% } else { %>
  <ul class="pf-sub-list">
    <% subs.forEach((s) => { %>
      <%
        const isApproved = s.status === 'approved';
        const isPending  = s.status === 'pending';
        const iconName = isApproved ? 'check-circle' : isPending ? 'hourglass' : 'x';
        const rowCls   = isApproved ? 'is-approved' : isPending ? 'is-pending' : 'is-rejected';
        const badgeCls = isApproved ? 'ok' : isPending ? 'wait' : 'no';
        const badgeTxt = isApproved ? 'Approvata' : isPending ? 'In attesa' : 'Rifiutata';
      %>
      <li class="pf-sub-row <%= rowCls %>">
        <span class="pf-sub-icon"><%- icon(iconName) %></span>
        <div class="pf-sub-body">
          <span class="pf-sub-title"><%= s.title %></span>
          <span class="pf-sub-meta"><%= s.points %> pt &nbsp;·&nbsp; <%= s.created_at %></span>
          <% if (s.status === 'rejected' && s.review_note) { %>
            <div class="pf-sub-note">Motivo: <%= s.review_note %></div>
          <% } %>
        </div>
        <span class="pf-sub-badge <%= badgeCls %>"><%= badgeTxt %></span>
      </li>
    <% }) %>
  </ul>
<% } %>

<%# ── FOTO PROFILO ─────────────────────────────────────────────────── %>
<div class="pf-form-card">
  <p class="pf-form-title"><%- icon('camera') %> Foto profilo</p>
  <div class="pf-avatar-row">
    <%- include('partials/avatar', { user: currentUser, cls: 'avatar-lg' }) %>
    <div class="pf-avatar-actions">
      <p class="muted small" style="margin-bottom:.7rem">
        Carica una foto: comparirà al posto delle iniziali <strong><%= initials(currentUser.nickname) %></strong>.
        JPEG, PNG, WebP o GIF, max <%= 8 %> MB.
      </p>
      <form action="/profilo/avatar" method="post" enctype="multipart/form-data" class="pf-avatar-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="file" name="avatar" accept="image/*" required id="avatarInput">
        <button class="btn" type="submit"><%- icon('camera') %> Carica foto</button>
      </form>
      <% if (currentUser.avatar_path) { %>
        <form action="/profilo/avatar/rimuovi" method="post" style="margin-top:.6rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="link-btn" type="submit"><%- icon('trash') %> Rimuovi foto e torna alle iniziali</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<%# ── CAMBIA PASSWORD ─────────────────────────────────────────────── %>
<div class="pf-form-card">
  <p class="pf-form-title"><%- icon('lock') %> Cambia password</p>
  <form action="/profilo/cambia-password" method="post" autocomplete="off" style="max-width:440px">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Password attuale
      <input type="password" name="current_password" required placeholder="la password che usi adesso">
    </label>
    <label>Nuova password
      <input type="password" name="new_password" required minlength="8" placeholder="almeno 8 caratteri">
    </label>
    <label>Conferma
      <input type="password" name="confirm_password" required minlength="8" placeholder="ripeti la nuova password">
    </label>
    <button class="btn" type="submit" style="margin-top:1rem">Aggiorna password</button>
  </form>
</div>

<%# ── ELIMINA ACCOUNT ─────────────────────────────────────────────── %>
<div class="pf-form-card pf-danger-card">
  <p class="pf-form-title"><%- icon('trash') %> Elimina account</p>
  <p class="muted small">Elimina definitivamente il tuo account e tutti i tuoi dati (prove, foto, storie, punti).
    <strong>Azione irreversibile.</strong></p>
  <form action="/profilo/elimina" method="post" autocomplete="off" style="max-width:440px"
        data-confirm="Sei sicuro di voler eliminare per sempre il tuo account e tutti i tuoi dati?">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Conferma la password per procedere
      <input type="password" name="password" required autocomplete="current-password" placeholder="la tua password">
    </label>
    <button class="btn btn-no" type="submit" style="margin-top:1rem"><%- icon('trash') %> Elimina il mio account</button>
  </form>
</div>
