<header class="topbar">
  <a class="brand" href="/">
    <span class="brand-full"><%- icon('logo-firework', 'brand-mark') %> FantaSanRocco</span>
    <span class="brand-short"><%- icon('logo-firework', 'brand-mark') %> FSR</span>
  </a>

  <%# Ruota della Fortuna — icona sempre accessibile nella barra %>
  <a href="/ruota" class="nav-wheel-btn <%= path === '/ruota' ? 'is-active' : '' %>" title="Ruota della Fortuna" aria-label="Ruota della Fortuna">
    <%- icon('wheel') %>
  </a>

  <%# Radio «Radio San Rocco» — mini player (espandibile) %>
  <% if (radioOn) { %>
  <div class="radio-mini" id="radioMini" data-state="paused">
    <button class="radio-mini-open" id="radioOpen" type="button" aria-label="Apri la radio" aria-haspopup="dialog">
      <span class="radio-mini-cover" id="radioMiniCover"></span>
      <span class="radio-mini-meta">
        <span class="radio-mini-kicker"><span class="radio-dot"></span>Radio</span>
        <span class="radio-mini-title" id="radioMiniTitle">Radio San Rocco</span>
      </span>
    </button>
    <button class="radio-mini-toggle" id="radioToggleMini" type="button" aria-label="Ascolta / Stop">
      <%- icon('play', 'ic-play') %><%- icon('pause', 'ic-pause') %>
    </button>
  </div>
  <% } %>

  <%# Saldo punti dell'utente loggato %>
  <% if (currentUser) { %>
    <a href="/profilo" class="nav-balance" title="I tuoi punti">
      <%- icon('trophy') %><span class="nav-balance-val"><%= userBalance %></span>
    </a>
  <% } %>

  <%# Online ora — subito a sinistra del pulsante menu %>
  <div class="online-pill" id="onlinePill" title="Online ora">
    <span class="online-dot"></span>
    <div class="oc-wrap"><span class="oc-val" id="onlineCount">—</span></div>
  </div>

  <%# Desktop nav → Mega-menu a tendina con anteprima immagini (hover) %>
  <%
    const mmItems = [
      { href: '/gioco',          label: 'Gioco',          img: '/images/galleria/palio-fuochi.jpg' },
      { href: '/classifica',     label: 'Classifica',     img: '/images/galleria/sanrocco-applausi.jpg' },
      { href: '/programmazione', label: 'Programmazione', img: '/images/menu/programmazione.png' },
      { href: '/galleria',       label: 'Galleria',       img: '/images/galleria/fuochi.webp' },
      { href: '/storia',         label: 'Storia',         img: '/images/galleria/processione-storica.jpg' },
      { href: '/premio',         label: 'Premio',         img: '/images/galleria/sanrocco-oro.jpg' },
    ];
    if (currentUser) {
      mmItems.push({ href: '/missioni', label: 'Missioni', img: '/images/galleria/fuochisti-preparano.jpg', active: path.startsWith('/missioni') });
      mmItems.push({ href: '/profilo',  label: 'Profilo',  avatar: true });
      if (currentUser.role === 'moderator' || currentUser.role === 'admin')
        mmItems.push({ href: '/moderazione', label: 'Modera', img: '/images/galleria/sanrocco-oro.jpg', staff: true });
      if (currentUser.role === 'admin')
        mmItems.push({ href: '/admin', label: 'Admin', img: '/images/galleria/sanrocco-oro.jpg', staff: true });
      mmItems.push({ logout: true, label: 'Esci', img: '/images/galleria/sanrocco-rientro-fuochi.jpg' });
    } else {
      mmItems.push({ href: '/registrati', label: 'Registrati', img: '/images/galleria/sanrocco-applausi.jpg' });
      mmItems.push({ href: '/login',      label: 'Accedi',     img: '/images/galleria/piazza.webp' });
    }
    mmItems.forEach((it) => { if (it.active === undefined) it.active = (path === it.href); });
  %>
  <nav class="nav megamenu" id="megamenu">
    <button class="mm-trigger" id="mmTrigger" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="mmPanel" aria-label="Apri il menu">
      <span class="mm-bars" aria-hidden="true"><span></span><span></span><span></span></span>
    </button>

    <div class="mm-panel" id="mmPanel" role="menu" aria-label="Navigazione">
      <ul class="mm-list">
        <% mmItems.forEach((it, i) => { %>
          <li>
            <% if (it.logout) { %>
              <form action="/logout" method="post" class="mm-logout-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" role="menuitem" class="mega-link is-staff" data-mm="<%= i %>"><span class="mega-link-text"><%= it.label %></span></button>
              </form>
            <% } else { %>
              <a role="menuitem" class="mega-link <%= it.active ? 'is-current' : '' %> <%= it.staff ? 'is-staff' : '' %>" href="<%= it.href %>" data-mm="<%= i %>">
                <span class="mega-link-text"><%= it.label %></span>
              </a>
            <% } %>
          </li>
        <% }) %>
      </ul>
      <div class="mm-stage" id="mmStage" aria-hidden="true">
        <% mmItems.forEach((it, i) => { %>
          <div class="mm-shot <%= i === 0 ? 'is-active' : '' %>" data-mm="<%= i %>">
            <% if (it.avatar) { %>
              <% if (currentUser && currentUser.avatar_path) { %>
                <img src="/avatar/<%= currentUser.avatar_path %>" alt="" loading="lazy">
              <% } else { %>
                <span class="mm-initials"><%= initials(currentUser ? currentUser.nickname : '') %></span>
              <% } %>
            <% } else { %>
              <img src="<%= it.img %>" alt="" loading="lazy">
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </nav>

  <%# Hamburger (mobile only) %>
  <button class="hamburger" id="hamburger" aria-label="Apri menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>

<%# ── Radio «Radio San Rocco» — popup espanso + audio condiviso ───── %>
<% if (radioOn) { %>
<div class="radio-modal" id="radioModal" hidden>
  <div class="radio-backdrop" id="radioBackdrop"></div>
  <div class="radio-card" id="radioCard" data-state="paused" role="dialog" aria-modal="true" aria-label="Radio Radio San Rocco">
    <button class="radio-close" id="radioClose" type="button" aria-label="Chiudi">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img class="radio-logo" src="/images/logoradio.png?v=1" alt="Radio San Rocco" width="100" height="100">
    <div class="radio-cover" id="radioCover"></div>
    <div class="radio-live"><span class="radio-dot"></span> In onda · per tutti</div>
    <div class="radio-listeners" id="radioListeners" hidden><span class="rl-dot"></span> <b id="radioListenersN">0</b>&nbsp;in ascolto ora</div>
    <h3 class="radio-title" id="radioTitle">Radio San Rocco</h3>
    <div class="radio-bar" id="radioBar"><div class="radio-bar-fill" id="radioBarFill"></div></div>
    <div class="radio-times"><span id="radioCur">0:00</span><span id="radioDur">0:00</span></div>
    <div class="radio-controls">
      <button class="radio-toggle" id="radioToggle" type="button" aria-label="Ascolta / Stop">
        <%- icon('play', 'ic-play') %><%- icon('pause', 'ic-pause') %>
        <span class="radio-toggle-label">Ascolta</span>
      </button>
    </div>
  </div>
</div>
<audio id="radioAudio" preload="none"></audio>
<% } %>

<%# ── Mobile overlay menu ─────────────────────────────────────────── %>
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <button class="mm-close" id="mmClose" aria-label="Chiudi menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <div class="mm-inner">
    <% if (currentUser) { %>
      <p class="mm-greeting">Ciao, <span><%= currentUser.nickname %></span></p>
    <% } %>

    <nav class="mm-nav">
      <a href="/"                class="mm-link" data-delay="0">Home</a>
      <a href="/missioni"        class="mm-link" data-delay="1">Missioni</a>
      <a href="/classifica"      class="mm-link" data-delay="2">Classifica</a>
      <a href="/programmazione"  class="mm-link" data-delay="3">Programmazione</a>
      <a href="/galleria"        class="mm-link" data-delay="4">Galleria</a>
      <a href="/gioco"           class="mm-link" data-delay="5">Gioco</a>
      <a href="/ruota"           class="mm-link" data-delay="6">Ruota della Fortuna</a>
      <a href="/slot"            class="mm-link" data-delay="7">Slot</a>
      <a href="/storia"          class="mm-link" data-delay="8">Storia</a>
      <a href="/premio"          class="mm-link" data-delay="9">Premi</a>
      <% if (currentUser) { %>
        <a href="/profilo"  class="mm-link" data-delay="10">Profilo</a>
        <% if (currentUser.role === 'moderator' || currentUser.role === 'admin') { %>
          <a href="/moderazione" class="mm-link mm-staff" data-delay="11">Moderazione</a>
        <% } %>
        <% if (currentUser.role === 'admin') { %>
          <a href="/admin" class="mm-link mm-staff" data-delay="12">Admin</a>
        <% } %>
      <% } %>
    </nav>

    <div class="mm-footer">
      <% if (currentUser) { %>
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="mm-logout" type="submit">Esci dall'account →</button>
        </form>
      <% } else { %>
        <a href="/registrati" class="btn" style="width:100%;justify-content:center;margin-bottom:.5rem">Registrati</a>
        <a href="/login" class="btn" style="width:100%;justify-content:center">Accedi e gioca</a>
      <% } %>
    </div>
  </div>
</div>

<%# ── Bottom tab bar (mobile, solo per loggati) ─────────────────── %>
<% if (currentUser) { %>
<nav class="bottom-nav" id="bottomNav">
  <a href="/" class="bn-item <%= path === '/' ? 'bn-active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
    </svg>
    <span>Home</span>
  </a>
  <a href="/missioni" class="bn-item <%= path.startsWith('/missioni') ? 'bn-active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>
    <span>Missioni</span>
  </a>
  <%# Pulsante centrale rialzato: cerchio dorato → Gioco %>
  <a href="/gioco" class="bn-game <%= path === '/gioco' ? 'bn-active' : '' %>" aria-label="Gioco">
    <span class="bn-game-circle"><%- icon('gamepad') %></span>
    <span class="bn-game-label">Gioco</span>
  </a>
  <a href="/classifica" class="bn-item <%= path === '/classifica' ? 'bn-active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
    </svg>
    <span>Classifica</span>
  </a>
  <a href="/profilo" class="bn-item <%= path === '/profilo' ? 'bn-active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/>
    </svg>
    <span>Profilo</span>
  </a>
</nav>
<% } %>
