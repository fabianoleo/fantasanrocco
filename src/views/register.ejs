<section class="card form-card">
  <h1>Registrati</h1>
  <p class="muted">Scegli un nickname e una password. L'email serve solo per recuperare la password se la dimentichi.</p>
  <form action="/registrati" method="post" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Nickname / Nome squadra
      <input type="text" name="nickname" required minlength="2" maxlength="24" placeholder="es. I Lupi di Siano">
    </label>
    <label>Email <span style="color:var(--red)">*</span>
      <input type="email" name="email" required placeholder="la tua email">
    </label>
    <label>Password
      <input type="password" name="password" required minlength="8" placeholder="almeno 8 caratteri">
    </label>
    <button class="btn" type="submit">Crea account</button>
  </form>
  <p class="muted small" style="margin-top:1rem">Hai già un account? <a href="/login">Accedi</a></p>
</section>
