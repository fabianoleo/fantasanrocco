<section class="card form-card">
  <h1><%- icon('key') %> Password dimenticata</h1>
  <p class="muted">Inserisci l'email associata al tuo account: riceverai un link per impostare una nuova password.</p>
  <form action="/password-dimenticata" method="post" autocomplete="off">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Email
      <input type="email" name="email" required placeholder="la tua email">
    </label>
    <button class="btn" type="submit">Invia link di reset</button>
  </form>
  <p class="muted small" style="margin-top:1rem">
    <a href="/login">← Torna al login</a>
  </p>
</section>
