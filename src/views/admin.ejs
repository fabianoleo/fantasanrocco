<h1>⚙️ Pannello Admin</h1>

<section class="card">
  <h2>🎟️ Inviti di registrazione</h2>
  <p class="muted small">Genera un link <strong>monouso</strong> per ogni persona: vale per
    una sola registrazione (un dispositivo). Copia il link e invialo (WhatsApp, ecc.).
    Dopo la registrazione si gioca dal normale <strong>/login</strong>.</p>

  <form action="/admin/inviti" method="post" class="row" style="align-items:flex-end">
    <label style="flex:2">Etichetta (facoltativa, es. nome)
      <input type="text" name="label" placeholder="es. Mario Rossi">
    </label>
    <label style="flex:1">Quanti
      <input type="number" name="count" value="1" min="1" max="100">
    </label>
    <button class="btn" type="submit">Genera</button>
  </form>

  <% const free = invites.filter(i => !i.used); const used = invites.filter(i => i.used); %>
  <h3 style="margin-top:1rem">Da consegnare (<%= free.length %>)</h3>
  <% if (free.length === 0) { %>
    <p class="muted small">Nessun invito disponibile: generane qui sopra.</p>
  <% } else { %>
    <ul class="invite-list">
      <% free.forEach((i) => { const link = baseUrl + '/registrati/' + i.token; %>
        <li class="invite-row">
          <div class="invite-info">
            <% if (i.label) { %><strong><%= i.label %></strong><% } %>
            <input class="invite-link" type="text" readonly value="<%= link %>" onclick="this.select()">
          </div>
          <div class="invite-actions">
            <button type="button" class="btn-mini copy-btn" data-copy="<%= link %>">Copia</button>
            <form action="/admin/inviti/<%= i.id %>/elimina" method="post" class="inline"
                  onsubmit="return confirm('Eliminare questo invito non ancora usato?');">
              <button type="submit" class="link-btn">elimina</button>
            </form>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <% if (used.length > 0) { %>
    <details style="margin-top:.6rem">
      <summary class="muted">Già usati (<%= used.length %>)</summary>
      <ul class="invite-list">
        <% used.forEach((i) => { %>
          <li class="invite-row used">
            <span><%= i.label ? i.label + ' · ' : '' %>usato da <strong><%= i.used_by_nick || '—' %></strong>
              <span class="muted small"><%= i.used_at %></span></span>
          </li>
        <% }) %>
      </ul>
    </details>
  <% } %>
</section>

<section class="card">
  <h2>➕ Nuova missione</h2>
  <form action="/admin/missioni" method="post" class="mission-form">
    <label>Titolo
      <input type="text" name="title" required placeholder="es. 🥃 Shot con Zio Max">
    </label>
    <label>Descrizione
      <textarea name="description" rows="2" placeholder="Cosa deve fare il partecipante"></textarea>
    </label>
    <div class="row">
      <label>Punti
        <input type="number" name="points" value="50" min="0">
      </label>
      <label class="check"><input type="checkbox" name="requires_photo" checked> Richiede foto</label>
      <label class="check"><input type="checkbox" name="repeatable"> Ripetibile</label>
    </div>
    <div class="row">
      <label>Attiva da (facoltativo)
        <input type="datetime-local" name="active_from">
      </label>
      <label>Attiva fino a (facoltativo)
        <input type="datetime-local" name="active_to">
      </label>
    </div>
    <button class="btn" type="submit">Crea missione</button>
  </form>
</section>

<section class="card">
  <h2>📋 Missioni esistenti (<%= missions.length %>)</h2>
  <% missions.forEach((m) => { %>
    <details class="admin-mission">
      <summary>
        <span><%= m.archived ? '🗄️ ' : '' %><%= m.title %></span>
        <span class="points-badge"><%= m.points %> pt</span>
      </summary>
      <form action="/admin/missioni/<%= m.id %>/modifica" method="post" class="mission-form">
        <label>Titolo<input type="text" name="title" value="<%= m.title %>" required></label>
        <label>Descrizione<textarea name="description" rows="2"><%= m.description %></textarea></label>
        <div class="row">
          <label>Punti<input type="number" name="points" value="<%= m.points %>" min="0"></label>
          <label class="check"><input type="checkbox" name="requires_photo" <%= m.requires_photo ? 'checked' : '' %>> Foto</label>
          <label class="check"><input type="checkbox" name="repeatable" <%= m.repeatable ? 'checked' : '' %>> Ripetibile</label>
          <label class="check"><input type="checkbox" name="archived" <%= m.archived ? 'checked' : '' %>> Archivia</label>
        </div>
        <div class="row">
          <label>Attiva da<input type="text" name="active_from" value="<%= m.active_from || '' %>" placeholder="2026-08-16 18:00"></label>
          <label>Attiva fino a<input type="text" name="active_to" value="<%= m.active_to || '' %>" placeholder="2026-08-17 03:00"></label>
        </div>
        <div class="mod-actions">
          <button class="btn" type="submit">💾 Salva</button>
        </div>
      </form>
      <form action="/admin/missioni/<%= m.id %>/elimina" method="post" class="danger-form"
            onsubmit="return confirm('Eliminare definitivamente questa missione e le sue prove?');">
        <button class="btn btn-no" type="submit">🗑️ Elimina</button>
      </form>
    </details>
  <% }) %>
</section>

<section class="card">
  <h2>👥 Utenti e ruoli (<%= users.length %>)</h2>
  <p class="muted small">Promuovi i tuoi collaboratori a <strong>moderatore</strong> (validano le prove)
    o <strong>admin</strong> (gestiscono tutto). Solo gli utenti normali compaiono in classifica.</p>
  <ul class="user-list">
    <% users.forEach((u) => { %>
      <li class="user-row">
        <span class="user-name"><%= u.nickname %>
          <span class="role-badge role-<%= u.role %>"><%= u.role %></span>
        </span>
        <form action="/admin/utenti/<%= u.id %>/ruolo" method="post" class="inline">
          <select name="role">
            <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
            <option value="moderator" <%= u.role === 'moderator' ? 'selected' : '' %>>moderator</option>
            <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
          </select>
          <button class="btn-mini" type="submit">Aggiorna</button>
        </form>
      </li>
    <% }) %>
  </ul>
</section>

<section class="card reset-card">
  <h2>🧨 Reset Gioco <span class="tag tag-off">solo test</span></h2>
  <p class="muted small">
    Cancella <strong>tutti gli utenti non-admin</strong>, le loro prove e tutti gli inviti.
    Gli account admin rimangono intatti. <strong>Azione irreversibile.</strong>
  </p>
  <form action="/admin/reset-gioco" method="post"
        onsubmit="return confirm('⚠️ RESET DEFINITIVO: vuoi davvero cancellare tutti i dati di gioco? Gli admin rimarranno.');">
    <label style="margin-bottom:.5rem">
      Scrivi <strong>RESET</strong> per confermare
      <input type="text" name="conferma" placeholder="RESET" autocomplete="off"
             style="max-width:160px; margin-top:.3rem">
    </label>
    <div>
      <button class="btn btn-no" type="submit">🧨 Reset Gioco</button>
    </div>
  </form>
</section>
