<h1 class="staff-title"><%- icon('gear') %> Pannello Admin</h1>

<section class="card">
  <h2 class="staff-title"><%- icon('plus') %> Nuova missione</h2>
  <form action="/admin/missioni" method="post" class="mission-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Titolo
      <input type="text" name="title" required placeholder="es. 🥃 Shot con Zio Max">
    </label>
    <label>Descrizione
      <textarea name="description" rows="2" placeholder="Cosa deve fare il partecipante"></textarea>
    </label>
    <div class="row">
      <label>Punti
        <input type="number" name="points" value="50" min="0">
      </label>
      <label class="check"><input type="checkbox" name="requires_photo" checked> Richiede foto</label>
      <label class="check"><input type="checkbox" name="repeatable"> Ripetibile</label>
    </div>
    <div class="row">
      <label>Attiva da (facoltativo)
        <input type="datetime-local" name="active_from">
      </label>
      <label>Attiva fino a (facoltativo)
        <input type="datetime-local" name="active_to">
      </label>
    </div>
    <button class="btn" type="submit">Crea missione</button>
  </form>
</section>

<section class="card">
  <h2 class="staff-title"><%- icon('list') %> Missioni esistenti (<%= missions.length %>)</h2>
  <% missions.forEach((m) => { %>
    <details class="admin-mission">
      <summary>
        <span><% if (m.archived) { %><%- icon('archive') %> <% } %><%= m.title %></span>
        <span class="points-badge"><%= m.points %> pt</span>
      </summary>
      <form action="/admin/missioni/<%= m.id %>/modifica" method="post" class="mission-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Titolo<input type="text" name="title" value="<%= m.title %>" required></label>
        <label>Descrizione<textarea name="description" rows="2"><%= m.description %></textarea></label>
        <div class="row">
          <label>Punti<input type="number" name="points" value="<%= m.points %>" min="0"></label>
          <label class="check"><input type="checkbox" name="requires_photo" <%= m.requires_photo ? 'checked' : '' %>> Foto</label>
          <label class="check"><input type="checkbox" name="repeatable" <%= m.repeatable ? 'checked' : '' %>> Ripetibile</label>
          <label class="check"><input type="checkbox" name="archived" <%= m.archived ? 'checked' : '' %>> Archivia</label>
        </div>
        <div class="row">
          <label>Attiva da<input type="text" name="active_from" value="<%= m.active_from || '' %>" placeholder="2026-08-16 18:00"></label>
          <label>Attiva fino a<input type="text" name="active_to" value="<%= m.active_to || '' %>" placeholder="2026-08-17 03:00"></label>
        </div>
        <div class="mod-actions">
          <button class="btn" type="submit"><%- icon('save') %> Salva</button>
        </div>
      </form>
      <form action="/admin/missioni/<%= m.id %>/elimina" method="post" class="danger-form"
            onsubmit="return confirm('Eliminare definitivamente questa missione e le sue prove?');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-no" type="submit"><%- icon('trash') %> Elimina</button>
      </form>
    </details>
  <% }) %>
</section>

<section class="card">
  <h2 class="staff-title"><%- icon('gift') %> Codici premio (link / QR)</h2>
  <p class="muted small">
    Genera un link premio: il <strong>primo utente loggato</strong> che lo apre riceve i punti,
    chi arriva dopo non guadagna nulla. Perfetto da stampare come QR ai vari punti della festa.
  </p>
  <form action="/admin/codici" method="post" class="mission-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="row">
      <label>Punti in palio
        <input type="number" name="points" value="50" min="1" required>
      </label>
      <label style="flex:1 1 220px">Etichetta (facoltativa, solo per te)
        <input type="text" name="label" placeholder="es. QR stand gadget">
      </label>
    </div>
    <button class="btn" type="submit"><%- icon('plus') %> Genera codice premio</button>
  </form>

  <% const codeList = (typeof codes !== 'undefined' && codes) ? codes : []; %>
  <% const base = (typeof baseUrl !== 'undefined' && baseUrl) ? baseUrl : ''; %>
  <% if (codeList.length) { %>
    <ul class="reward-list">
      <% codeList.forEach((c) => { %>
        <li class="reward-row">
          <div class="reward-head">
            <span class="reward-label"><%= c.label || 'Codice premio' %></span>
            <span class="points-badge"><%= c.points %> pt</span>
            <% if (c.claimed_by) { %>
              <span class="tag tag-off">usato da <%= c.claimer || '—' %></span>
            <% } else { %>
              <span class="tag tag-on">libero</span>
            <% } %>
          </div>
          <input class="reward-link" type="text" readonly onclick="this.select()"
                 value="<%= base %>/r/<%= c.code %>">
          <form action="/admin/codici/<%= c.code %>/elimina" method="post" class="inline"
                onsubmit="return confirm('Eliminare questo codice premio?');">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-mini" type="submit"><%- icon('trash') %> Elimina</button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="muted small">Nessun codice premio ancora. Creane uno qui sopra.</p>
  <% } %>
</section>

<section class="card">
  <h2 class="staff-title"><%- icon('people') %> Utenti e ruoli (<%= users.length %>)</h2>
  <p class="muted small">Promuovi i tuoi collaboratori a <strong>moderatore</strong> (validano le prove)
    o <strong>admin</strong> (gestiscono tutto). Solo gli utenti normali compaiono in classifica.</p>
  <ul class="user-list">
    <% users.forEach((u) => { %>
      <li class="user-row">
        <span class="user-name"><%= u.nickname %>
          <span class="role-badge role-<%= u.role %>"><%= u.role %></span>
        </span>
        <form action="/admin/utenti/<%= u.id %>/ruolo" method="post" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="role">
            <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
            <option value="moderator" <%= u.role === 'moderator' ? 'selected' : '' %>>moderator</option>
            <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
          </select>
          <button class="btn-mini" type="submit">Aggiorna</button>
        </form>
      </li>
    <% }) %>
  </ul>
</section>

<section class="card reset-card">
  <h2 class="staff-title"><%- icon('bolt') %> Reset Gioco <span class="tag tag-off">solo test</span></h2>
  <p class="muted small">
    Cancella <strong>tutti gli utenti non-admin</strong> (con email liberate: si potrà
    ri-registrare la stessa mail), le loro <strong>prove e foto</strong>, le <strong>storie</strong>
    e azzera la <strong>classifica</strong>. Restano <strong>missioni</strong> e <strong>codici premio</strong>
    (i link/QR tornano riscattabili). Gli account admin restano, ma con statistiche di gioco azzerate.
    <strong>Azione irreversibile.</strong>
  </p>
  <form action="/admin/reset-gioco" method="post"
        onsubmit="return confirm('⚠️ RESET DEFINITIVO: vuoi davvero cancellare tutti i dati di gioco? Gli admin rimarranno.');">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label style="margin-bottom:.5rem">
      Scrivi <strong>RESET</strong> per confermare
      <input type="text" name="conferma" placeholder="RESET" autocomplete="off"
             style="max-width:160px; margin-top:.3rem">
    </label>
    <label style="margin-bottom:.5rem; margin-top:.5rem">
      Inserisci la tua <strong>password admin</strong>
      <input type="password" name="admin_password" placeholder="Password" autocomplete="current-password"
             style="max-width:220px; margin-top:.3rem">
    </label>
    <div>
      <button class="btn btn-no" type="submit"><%- icon('bolt') %> Reset Gioco</button>
    </div>
  </form>
</section>
