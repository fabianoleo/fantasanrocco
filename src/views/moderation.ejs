<h1 class="staff-title"><%- icon('shield') %> Moderazione</h1>
<p class="muted">Prove in attesa: <strong><%= pending.length %></strong>.
  Se due moderatori aprono la stessa, vince il primo che clicca: l'altro vedrà un avviso.</p>

<% if (pending.length === 0) { %>
  <p class="muted">Nessuna prova in attesa. Tutto sotto controllo! <span style="color:var(--green)"><%- icon('check') %></span></p>
<% } else { %>
  <div class="mod-list">
    <% let modCurrentUser = null; %>
    <% pending.forEach((s) => { %>
      <% if (s.nickname !== modCurrentUser) { modCurrentUser = s.nickname; %>
        <div class="mod-user-header">
          <span class="mod-user-name"><%= s.nickname %></span>
          <span class="mod-user-count"><%= pending.filter(x => x.nickname === s.nickname).length %> in attesa</span>
        </div>
      <% } %>
      <section class="card mod-card">
        <div class="mod-top">
          <div>
            <strong><%= s.nickname %></strong> → <%= s.title %>
            <span class="points-badge"><%= s.points %> pt</span>
            <% if (s.duplicati && s.duplicati.length) { %>
              <span class="mod-dup-badge"><%- icon('warning') %> Già vista</span>
            <% } %>
          </div>
          <span class="muted small"><%= s.created_at %></span>
        </div>

        <%# ── Foto già vista altrove: confronto affiancato ─────────────── %>
        <% const dup = (s.duplicati && s.duplicati.length) ? s.duplicati : null; %>
        <% if (s.photo_path && !s.phash) { %>
          <p class="muted small mod-noimpronta">
            <%- icon('warning') %> Controllo duplicati non eseguito su questa foto
            (formato che non riusciamo a leggere). Guardala tu.
          </p>
        <% } %>
        <% if (dup) { %>
          <div class="mod-dup">
            <p class="mod-dup-head">
              <%- icon('warning') %>
              <strong><%= dup[0].identica ? 'Foto identica' : 'Foto quasi identica' %></strong>
              a <%= dup.length === 1 ? 'una prova già inviata' : dup.length + ' prove già inviate' %>.
              Guarda il confronto e decidi tu.
            </p>
            <% dup.slice(0, 3).forEach((d) => { const gruppo = 'dup-' + s.id + '-' + d.id; %>
              <div class="mod-dup-row">
                <figure class="mod-dup-fig">
                  <a href="/uploads/<%= s.photo_path %>" data-lightbox data-group="<%= gruppo %>"
                     data-caption="Questa · <%= s.nickname %> · <%= s.title %>">
                    <img src="/uploads/<%= s.photo_path %>" alt="La prova in esame" loading="lazy">
                  </a>
                  <figcaption>Questa · <%= s.nickname %></figcaption>
                </figure>
                <span class="mod-dup-vs" aria-hidden="true">=</span>
                <figure class="mod-dup-fig">
                  <a href="/uploads/<%= d.photo_path %>" data-lightbox data-group="<%= gruppo %>"
                     data-caption="<%= d.stessoUtente ? 'Stesso utente' : d.nickname %> · <%= d.missione %> · <%= d.stato %>">
                    <img src="/uploads/<%= d.photo_path %>" alt="La prova già inviata" loading="lazy">
                  </a>
                  <figcaption>
                    <%= d.stessoUtente ? 'Stesso utente' : d.nickname %> · <%= d.missione %><br>
                    <span class="muted"><%= d.stato %> · <%= d.quando %></span>
                  </figcaption>
                </figure>
              </div>
            <% }) %>
            <% if (dup.length > 3) { %>
              <p class="muted small">…e altre <%= dup.length - 3 %>.</p>
            <% } %>
          </div>
        <% } %>

        <% if (s.photo_path) { %>
          <a href="/uploads/<%= s.photo_path %>" data-lightbox
             data-caption="<%= s.nickname %> · <%= s.title %>">
            <img class="mod-photo" src="/uploads/<%= s.photo_path %>" alt="prova" loading="lazy">
          </a>
        <% } else if (s.requires_photo) { %>
          <p class="tag-off"><%- icon('warning') %> Manca la foto (anomalia)</p>
        <% } else { %>
          <p class="muted small">Missione senza foto (auto-dichiarata).</p>
        <% } %>

        <% if (s.note) { %><p class="muted small">Nota: <%= s.note %></p><% } %>

        <div class="mod-actions">
          <form action="/moderazione/<%= s.id %>/approva" method="post" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-ok" type="submit"><%- icon('check') %> Approva</button>
          </form>
          <form action="/moderazione/<%= s.id %>/rifiuta" method="post" class="inline reject-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="text" name="review_note" placeholder="motivo (facoltativo)" maxlength="200">
            <button class="btn btn-no" type="submit"><%- icon('x') %> Rifiuta</button>
          </form>
        </div>
      </section>
    <% }) %>
  </div>
<% } %>
