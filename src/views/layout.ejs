<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#000000">
  <meta name="description" content="Il gioco della festa di San Rocco a Siano (SA) — Completa missioni, accumula punti, vinci premi.">
  <title><%= title %> · FantaSanRocco</title>
  <%# Font serviti da Bunny Fonts: drop-in di Google Fonts ma EU/GDPR-compliant (nessun log IP).
      NB: un link per famiglia — l'endpoint combinato multi-famiglia di Bunny è bacato
      (restituisce solo la prima famiglia), quindi Cinzel Decorative/Cormorant/Inter sparivano. %>
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin>
  <link href="https://fonts.bunny.net/css2?family=Cinzel:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.bunny.net/css2?family=Cinzel+Decorative:wght@400;700;900&display=swap" rel="stylesheet">
  <link href="https://fonts.bunny.net/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap" rel="stylesheet">
  <link href="https://fonts.bunny.net/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.bunny.net/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css?v=81">
  <link rel="stylesheet" href="/radio.css?v=3">

  <%# ── PWA (installabile + offline + notifiche) ── %>
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="FantaSanRocco">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <meta name="vapid-public-key" content="<%= typeof vapidPublicKey !== 'undefined' ? vapidPublicKey : '' %>">
</head>
<body>

  <%# ── Banner prudenza (mostrato una volta per sessione) ── %>
  <div class="safety-overlay" id="safetyOverlay" aria-modal="true" role="dialog">
    <div class="safety-card">
      <div class="safety-icon"><%- icon('shield-check') %></div>
      <h2 class="safety-title">Gioca con la testa</h2>
      <p class="safety-intro">
        FantaSanRocco è un gioco goliardico per la Festa di San Rocco a Siano.<br>
        Divertiti, ma ricordati di:
      </p>
      <ul class="safety-list">
        <li><span class="safety-emo" aria-hidden="true">🍷</span> Bere con moderazione e responsabilità</li>
        <li><span class="safety-emo" aria-hidden="true">🚗</span> Non mettersi alla guida dopo aver bevuto</li>
        <li><span class="safety-emo" aria-hidden="true">🤝</span> Rispettare le persone intorno a sé</li>
        <li><span class="safety-emo" aria-hidden="true">🎆</span> Seguire le norme di sicurezza durante i festeggiamenti</li>
        <li><span class="safety-emo" aria-hidden="true">🚑</span> In caso di emergenza chiamare il 118</li>
      </ul>
      <button class="btn safety-btn" id="safetyAccept">Ho capito — inizia il gioco →</button>
      <p class="safety-fine">Partecipando dichiari di comportarti in modo responsabile durante la festa.</p>
    </div>
  </div>

  <%- include('partials/nav') %>

  <%- include('partials/stories') %>
  <%- include('partials/streak') %>

  <main class="container">
    <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>"><%= flash.msg %></div>
    <% } %>
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="site-footer__pin">
      <div class="site-footer__sticky">
        <div class="site-footer__inner">
          <span class="site-footer__glow" aria-hidden="true"></span>

          <div class="foot-top">
            <div class="foot-brand foot-col">
              <img src="/images/logo.png?v=1" alt="Fanta San Rocco" class="foot-logo" width="84" height="84" loading="lazy">
              <p class="foot-tagline">Il gioco della Festa di San Rocco a Siano. Completa le missioni, scala la classifica e vinci premi insieme alla tua gente.</p>
              <div class="foot-socials">
                <a class="foot-social" href="https://www.instagram.com/fanta_sanrocco/" target="_blank" rel="noopener noreferrer" aria-label="Seguici su Instagram @fanta_sanrocco">
                  <%- icon('instagram') %><span>@fanta_sanrocco</span>
                </a>
                <a class="foot-social" href="https://www.tiktok.com/@fantasanrocco" target="_blank" rel="noopener noreferrer" aria-label="Seguici su TikTok @fantasanrocco">
                  <%- icon('tiktok') %><span>@fantasanrocco</span>
                </a>
              </div>
            </div>

            <nav class="foot-group foot-col" aria-label="Gioca">
              <h3>Gioca</h3>
              <ul>
                <li><a href="/gioco">Gioco</a></li>
                <li><a href="/ruota">Ruota della Fortuna</a></li>
                <li><a href="/slot">Slot</a></li>
                <li><a href="/missioni">Missioni</a></li>
              </ul>
            </nav>

            <nav class="foot-group foot-col" aria-label="La Festa">
              <h3>La Festa</h3>
              <ul>
                <li><a href="/programmazione">Programmazione</a></li>
                <li><a href="/palio">Palio dei Fuochi</a></li>
                <li><a href="/galleria">Galleria</a></li>
                <li><a href="/storia">Storia</a></li>
                <li><a href="/premio">Premi</a></li>
              </ul>
            </nav>

            <nav class="foot-group foot-col" aria-label="Community">
              <h3>Community</h3>
              <ul>
                <li><a href="/classifica">Classifica</a></li>
                <% if (currentUser) { %>
                  <li><a href="/profilo">Profilo</a></li>
                <% } else { %>
                  <li><a href="/login">Accedi</a></li>
                  <li><a href="/registrati">Registrati</a></li>
                <% } %>
              </ul>
            </nav>
          </div>

          <div class="foot-bottom">
            <p>© <%= new Date().getFullYear() %> FantaSanRocco · Festa di San Rocco · Siano (SA) · <a href="/privacy">Privacy</a> · <a href="/termini">Termini</a></p>
            <p class="foot-motto">ad maiora <%- icon('fireworks') %></p>
          </div>
        </div>
      </div>
    </div>
  </footer>
  <script src="/app.js?v=6"></script>
  <script src="/radio.js?v=7" defer></script>
  <script src="/menu.js?v=1" defer></script>
  <script src="/pwa.js?v=3" defer></script>
</body>
</html>
