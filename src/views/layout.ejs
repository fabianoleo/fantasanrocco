<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#000000">
  <meta name="description" content="Il gioco della festa di San Rocco a Siano (SA) — Completa missioni, accumula punti, vinci premi.">
  <title><%= title %> · FantaSanRocco</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    body { font-family: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container">
    <% if (flash) { %>
      <div class="flash flash-<%= flash.type %>"><%= flash.msg %></div>
    <% } %>
    <%- body %>
  </main>

  <footer class="footer">
    <p>FantaSanRocco &nbsp;·&nbsp; Festa di San Rocco &nbsp;·&nbsp; Siano (SA) &nbsp;·&nbsp; ad maiora 🎆</p>
  </footer>
  <script src="/app.js"></script>
</body>
</html>
