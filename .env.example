# Copia questo file in ".env" e personalizzalo.
# (cp .env.example .env)

# Porta su cui gira l'app dentro il container / in locale
PORT=3000

# Cartella dove vengono salvati database e foto caricate.
# In Docker è montata come volume, NON cambiarla se usi docker compose.
DATA_DIR=./data

# Segreto per firmare i cookie di sessione.
# IMPORTANTISSIMO: mettine uno lungo e casuale e NON condividerlo.
# Generane uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambiami-con-una-stringa-lunga-e-casuale

# Metti "true" SOLO quando l'app è esposta in HTTPS (es. tramite Cloudflare Tunnel).
# In locale (http://localhost) lascialo "false", altrimenti il login non funziona.
SECURE_COOKIES=false

# Dimensione massima foto in MB
MAX_UPLOAD_MB=8

# URL pubblico dell'app (con https://). OBBLIGATORIO in produzione.
# I link di reset password si costruiscono SOLO da qui, MAI dall'header Host
# della richiesta (altrimenti un attaccante potrebbe falsificarlo e rubare il
# token di reset). In locale puoi lasciare il default localhost.
APP_URL=http://localhost:3000
